# 10 Classe Data com Método de vclasse


class Data:

    def __init__(self, dia, mes, ano):
        self.dia = dia
        self.mes = mes
        self.ano = ano

    @classmethod
    def de_string(cls, data_str):
        d, m, a = data_str.split("/")
        return cls(int(d), int(m), int(a))

    def __str__(self):
        return f"{self.dia:02d}/{self.mes:02d}/{self.ano}"


d1 = Data(10, 4, 2026)
d2 = Data.de_string("25/12/2025")

print(d1)
print(d2)


